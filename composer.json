{
    "name": "venne-media/contao-git-push",
    "description": "Enterprise-grade backend module for Git operations in Contao 5.3",
    "type": "contao-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Venne Media GmbH",
            "homepage": "https://venne-media.de"
        }
    ],
    "require": {
        "php": ">=8.2",
        "contao/core-bundle": "^5.3",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/test-pack": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "VennMedia\\VmGitPushBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VennMedia\\VmGitPushBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "contao-manager-plugin": "VennMedia\\VmGitPushBundle\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true
        }
    }
}
